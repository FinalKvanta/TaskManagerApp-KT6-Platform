<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:TaskManagerApp"
             xmlns:conv="clr-namespace:TaskManagerApp.Converters"
             x:Class="TaskManagerApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
            <conv:BoolToIconConverter x:Key="BoolToIconConverter" />
            <conv:PriorityColorConverter x:Key="PriorityColorConverter" />
            <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
            <conv:BoolToStatusBtnConverter x:Key="BoolToStatusBtnConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
